<UserControl x:Class="KeepAttributesHorizontal.UI.AiAssistantControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="400" Background="#1E1E1E">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border BorderBrush="#3E3E42" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10">
            <TextBlock Text="CADY CoPilot" FontSize="18" FontWeight="SemiBold" Foreground="#E5E5E5" HorizontalAlignment="Center"/>
        </Border>

        <!-- Chat Area -->
        <ScrollViewer x:Name="ChatScroller" Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="MessagesPanel">
                <!-- Welcome / Info -->
                <TextBlock Text="I might make mistakes, so check for accuracy." Foreground="#969696" FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,20"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Input Box Area -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <Border Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="6" Padding="10" Grid.Row="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ComboBox x:Name="ModeSelector" Background="#3E3E42" Foreground="Black" Margin="0,0,0,10" SelectedIndex="0" Grid.Row="0">
                        <ComboBoxItem Content="Design Validation Mode" />
                        <ComboBoxItem Content="Agent Mode" />
                    </ComboBox>

                    <TextBox x:Name="ChatInputBox" Grid.Row="1" Background="Transparent" Foreground="#E5E5E5" BorderThickness="0" 
                             AcceptsReturn="True" TextWrapping="Wrap" 
                             Text="Ask Copilot or use @workspace" 
                             GotFocus="ChatInputBox_GotFocus" LostFocus="ChatInputBox_LostFocus"
                             MinHeight="40" MaxHeight="100" VerticalScrollBarVisibility="Auto"/>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Content="+" Width="28" Height="28" Background="Transparent" Foreground="#969696" BorderThickness="0" ToolTip="Attach reference" Cursor="Hand"/>

                        <Button Grid.Column="2" Content="?" Width="32" Height="28" Background="#007ACC" Foreground="White" BorderThickness="0" Click="SendMessage_Click" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>